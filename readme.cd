│   ├── routes/
│   │   ├── authRoutes.js
│   │   └── issueRoutes.js
│   └── services/
│       └── escalationService.js # setInterval cron
│
└── Frontend/
    ├── vite.config.js       # proxy: /api → localhost:5000
    ├── vercel.json          # SPA rewrite rules
    ├── .env                 # VITE_API_URL=/api (dev) or full URL (prod)
    └── src/
        ├── constants/       # Categories, thresholds, style maps
        ├── services/api.js  # authAPI + issueAPI
        ├── context/         # AuthContext, IssueContext
        ├── hooks/           # useIssueForm
        ├── components/      # Navbar, IssueCard, MapPicker, AllIssuesMap…
        └── pages/           # HomePage, ReportPage, IssuesPage,
                             #   AdminPage, SignupPage, MapPage…
```

